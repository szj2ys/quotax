{
  "description": "B2B报价展示工具",
  "packOptions": {
    "ignore": [
      {
        "type": "regexp",
        "value": "\\.tsx?$"
      },
      {
        "type": "regexp",
        "value": "\\.scss$"
      }
    ],
    "include": []
  },
  "setting": {
    "urlCheck": false,
    "es6": true,
    "enhance": true,
    "postcss": false,
    "preloadBackgroundData": false,
