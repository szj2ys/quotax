# 环境变量示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 基础配置
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# 数据库配置
# ============================================
# MongoDB 连接字符串
# 格式: mongodb://[用户名]:[密码]@[主机]:[端口]/[数据库名]?authSource=admin
MONGODB_URI=mongodb://localhost:27017/quotax

# 连接池配置
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_SOCKET_TIMEOUT=45000
MONGODB_SERVER_SELECTION_TIMEOUT=30000
MONGODB_MAX_IDLE_TIME=60000
MONGODB_WAIT_QUEUE_TIMEOUT=5000
MONGODB_HEARTBEAT_FREQ=10000

# MongoDB root 用户（仅用于 docker-compose）
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_me_in_production

# ============================================
# 安全配置
# ============================================
# JWT 密钥（必须修改！至少32位随机字符串）
JWT_SECRET=your-super-secret-key-change-me-in-production-min-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 密码加密轮数
BCRYPT_ROUNDS=12

# ============================================
# 微信小程序配置
# ============================================
# 小程序 AppID（从微信公众平台获取）
WECHAT_APPID=wx1234567890abcdef

# 小程序 AppSecret（从微信公众平台获取）
WECHAT_APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# CORS 配置
# ============================================
# 允许的跨域来源，多个用逗号分隔
CLIENT_ORIGIN=https://quotax.com,https://www.quotax.com

# ============================================
# 日志配置
# ============================================
# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# 日志格式: json 或 simple
LOG_FORMAT=json

# ============================================
# 限流配置
# ============================================
# 每窗口最大请求数
RATE_LIMIT_MAX=100

# 限流窗口时间（毫秒）
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# 上传配置
# ============================================
# 最大上传文件大小（字节）
UPLOAD_MAX_SIZE=5242880

# 上传目录
UPLOAD_DIR=uploads
